# Скопировать в .env (рядом), вписать значения. .env в git не попадает.

# Токен ТЕСТОВОГО бота от @BotFather.
# Боевой токен скомпрометирован — не использовать, отозвать через /revoke.
BOT_TOKEN=

# HTTPS-адрес Mini App: URL cloudflared-туннеля или домен сервера.
WEBAPP_URL=

# Порт локального сервера статики (prototype/)
PORT=8737

# КАНАЛ админов: карточки заявок и фото сдачи падают сюда.
# Создать канал -> добавить бота администратором -> переслать любой пост канала боту в личку,
# бот ответит id (число с -100...). Группа тоже работает (в ней /chatid).
ADMIN_CHAT_ID=

# Только для локальной разработки БЕЗ Telegram: все запросы без подписи = этот пользователь.
# НА ПРОДЕ НЕ ЗАДАВАТЬ.
# DEV_USER_ID=

# Telegram ID через запятую. Старшие автоматически имеют права админа.
# Свой ID: написать боту @userinfobot или взять из /chatid в личке с ботом.
ADMIN_IDS=
SENIOR_ADMIN_IDS=

# Hidden until the role is introduced. Set to 1 and restart to restore it.
ENABLE_PRODUCTION_ROLE=0

# Direct Google Sheets score synchronization. Disabled mode keeps a local queue.
GOOGLE_SHEETS_ENABLED=0
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_SHEET_EVENTS_TAB=Начисления
GOOGLE_SHEET_SUMMARY_TAB=Админы

# Exact decimal score values.
SCORE_DAILY_ADMIN=0.1
SCORE_REQUEST=0.01
SCORE_626=0.05


# Closed members directory. Uses the same Service Account as score sync.
MEMBERS_SHEET_ID=
MEMBERS_SHEET_TAB=люди
# Local development alternative to GOOGLE_SERVICE_ACCOUNT_JSON_B64.
GOOGLE_SERVICE_ACCOUNT_FILE=

# Legacy button-bot recipients. Password is required by /migrateold.
LEGACY_DB_PATH=equipment_bot.sqlite3
LEGACY_MIGRATION_PASSWORD=

# Older optional verification sources; the closed members sheet has priority.
MB_SHEET_URL=
ORG_MEMBERS_FILE=org_members.csv
DIRECTORY_FILE=
